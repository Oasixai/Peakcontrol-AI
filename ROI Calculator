  initCalculator() {

      /* =========================================================
         SAVINGS LOGIC
         "Cost Saved" reflects the real drivers of procurement ROI,
         not just raw hours × hourly rate:

         1) HEADCOUNT AVOIDED (dominant driver) — the manual workload
            (PO volume × time/PO) is converted into FTEs required,
            using the standard FTE benchmark of 173.33 hrs/month
            (2,080 annual hours ÷ 12). Rather than a hard "subtract
            1 FTE" step (which caused ROI to jump sharply once
            workload crossed the 1-FTE line), headcount savings ramp
            in gradually using a saturating curve: the fraction of
            workload counted as "avoided" grows smoothly from 0
            toward ~1 as PO volume increases, governed by a smoothing
            constant (RAMP_SMOOTHING). This produces a gradual ROI
            curve instead of a cliff.

         2) ERROR REDUCTION — manual PO/invoice processes carry a
            baseline error rate (mispricing, duplicate orders,
            mismatched invoices). We assume a conservative 3% of
            the manual labor cost is recovered through fewer errors.

         PRICING LOGIC
         PeakControl's confirmed starter price is $1,700/month for
         small customers. Pricing is a hybrid: a base fee that scales
         mildly with PO volume, plus a value-capture component on
         savings created. Tuned so ROI ramps gradually and only
         approaches its ceiling (~6x) at the absolute maximum of all
         three sliders — typical/mid-range usage lands well below
         that, in the 2-5x band.
         ========================================================= */
      const FTE_MONTHLY_HOURS = 173.33; // standard FTE benchmark (2,080 hrs/yr ÷ 12)
      const ERROR_REDUCTION_RATE = 0.03; // 3% of manual labor cost recovered via fewer errors
      const VALUE_CAPTURE_RATE = 0.16; // % of value created, layered on top of base fee
      const RAMP_SMOOTHING = 3; // higher = slower, more gradual ROI ramp

      // -- AI cost basis -----------------------------------------------------
      // Measured from the live PeakControl prototype on Claude Sonnet 4.6:
      // a fully resolved PO (1 initial follow-up + ~2 supplier reply cycles)
      // consumes ~3,500 input tokens and ~800 output tokens. We bill the
      // customer the raw Anthropic cost plus a hidden margin — never surfaced
      // as a separate line item.
      const AI_TOKENS_PER_PO_INPUT  = 3500;
      const AI_TOKENS_PER_PO_OUTPUT = 800;
      const ANTHROPIC_INPUT_USD_MTOK  = 3.0;  // Sonnet 4.6 list price
      const ANTHROPIC_OUTPUT_USD_MTOK = 15.0;
      const HIDDEN_AI_MARGIN = 0.30; // 30%, baked silently into customer pricing
      const SHOW_INTERNAL = (() => {
        try {
          return new URLSearchParams(window.location.search).get('internal') === '1';
        } catch (e) { return false; }
      })();

      function aiCostRawPerPO(){
        return (
          (AI_TOKENS_PER_PO_INPUT  * ANTHROPIC_INPUT_USD_MTOK) +
          (AI_TOKENS_PER_PO_OUTPUT * ANTHROPIC_OUTPUT_USD_MTOK)
        ) / 1000000;
      }

      function getTierBase(pos){
        if (pos <= 750)  return 1700; // confirmed starter price
        if (pos <= 1500) return 2200;
        if (pos <= 2500) return 2800;
        if (pos <= 3500) return 3400;
        return 4000; // up to 5000
      }

      const posEl  = this.shadowRoot.getElementById('pos');
      const timeEl = this.shadowRoot.getElementById('time');
      const costEl = this.shadowRoot.getElementById('cost');

      const posValue  = this.shadowRoot.getElementById('pos-value');
      const timeValue = this.shadowRoot.getElementById('time-value');
      const costValue = this.shadowRoot.getElementById('cost-value');

      const fillPos  = this.shadowRoot.getElementById('fill-pos');
      const fillTime = this.shadowRoot.getElementById('fill-time');
      const fillCost = this.shadowRoot.getElementById('fill-cost');

      const timeSavedEl = this.shadowRoot.getElementById('time-saved');
      const costSavedEl = this.shadowRoot.getElementById('cost-saved');
      const roiEl        = this.shadowRoot.getElementById('roi-value');

      // Internal panel element refs (used only when SHOW_INTERNAL is on)
      const internalPanel = this.shadowRoot.getElementById('internal-panel');
      const ipTokens      = this.shadowRoot.getElementById('ip-tokens');
      const ipTokensHint  = this.shadowRoot.getElementById('ip-tokens-hint');
      const ipAnthropic   = this.shadowRoot.getElementById('ip-anthropic');
      const ipAnthropicH  = this.shadowRoot.getElementById('ip-anthropic-hint');
      const ipAnthropicRow= this.shadowRoot.getElementById('ip-anthropic-row');
      const ipAiBilled    = this.shadowRoot.getElementById('ip-ai-billed');
      const ipAiMargin    = this.shadowRoot.getElementById('ip-ai-margin');
      const ipTier        = this.shadowRoot.getElementById('ip-tier');
      const ipVc          = this.shadowRoot.getElementById('ip-vc');
      const ipRevenue     = this.shadowRoot.getElementById('ip-revenue');
      const ipMargin      = this.shadowRoot.getElementById('ip-margin');
      const ipMarginPct   = this.shadowRoot.getElementById('ip-margin-pct');
      const ipMarginHint  = this.shadowRoot.getElementById('ip-margin-hint');

      if (SHOW_INTERNAL && internalPanel) {
        internalPanel.classList.add('visible');
      }

      function fmt(n){ return Math.round(n).toLocaleString('en-US'); }
      function fmtMoney(n){ return '$' + fmt(n); }
      function fmtSignedMoney(n){
        if (n >= 0) return '+$' + fmt(n);
        return '-$' + fmt(Math.abs(n));
      }

      function updateInternalPanel(ctx){
        const totalIn  = ctx.pos * AI_TOKENS_PER_PO_INPUT;
        const totalOut = ctx.pos * AI_TOKENS_PER_PO_OUTPUT;
        const totalTokens = totalIn + totalOut;
        const revenue = ctx.tierBase + ctx.valueCapture + ctx.aiCostBilled;
        const grossMargin = revenue - ctx.aiCostRaw;
        const grossMarginPct = revenue > 0 ? (grossMargin / revenue) * 100 : 0;
        const aiMargin = ctx.aiCostBilled - ctx.aiCostRaw;
        const perPo = ctx.pos > 0 ? ctx.aiCostRaw / ctx.pos : 0;

        ipTokens.textContent     = (totalTokens / 1000000).toFixed(2) + ' M';
        ipTokensHint.textContent = fmt(totalIn) + ' in · ' + fmt(totalOut) + ' out';
        ipAnthropic.textContent  = fmtMoney(ctx.aiCostRaw);
        ipAnthropicH.textContent = 'Sonnet 4.6 list · $' + perPo.toFixed(3) + ' / PO';
        ipMarginPct.textContent  = grossMarginPct.toFixed(1) + '%';
        ipMarginHint.textContent = fmtMoney(grossMargin) + ' / month';

        ipAnthropicRow.textContent = '-' + fmtMoney(ctx.aiCostRaw);
        ipAiBilled.textContent     = fmtMoney(ctx.aiCostBilled);
        ipAiMargin.textContent     = '+' + fmtMoney(aiMargin);
        ipTier.textContent         = fmtMoney(ctx.tierBase);
        ipVc.textContent           = fmtMoney(ctx.valueCapture);
        ipRevenue.textContent      = fmtMoney(revenue);
        ipMargin.textContent       = fmtMoney(grossMargin);
      }

      function updateFill(input, fillEl){
        const min = parseFloat(input.min);
        const max = parseFloat(input.max);
        const val = parseFloat(input.value);
        const pct = ((val - min) / (max - min)) * 100;
        fillEl.style.width = pct + '%';
      }

      function pulse(el){
        el.classList.remove('pulse');
        void el.offsetWidth; // restart animation
        el.classList.add('pulse');
      }

      function recalc(){
        const pos  = parseFloat(posEl.value);
        const time = parseFloat(timeEl.value);
        const cost = parseFloat(costEl.value);

        // Labels
        posValue.textContent  = fmt(pos);
        timeValue.textContent = fmt(time);
        costValue.textContent = '$' + fmt(cost);

        // Track fills
        updateFill(posEl, fillPos);
        updateFill(timeEl, fillTime);
        updateFill(costEl, fillCost);

        // Manual workload, converted to FTEs required
        const manualHours = (pos * time) / 60;
        const fteNeeded = manualHours / FTE_MONTHLY_HOURS;
        const monthlySalary = cost * FTE_MONTHLY_HOURS;

        // Headcount avoided: smooth saturating ramp instead of a hard step,
        // so ROI builds gradually rather than jumping once workload crosses 1 FTE
        const avoidedFraction = fteNeeded / (fteNeeded + RAMP_SMOOTHING);
        const fteAvoided = fteNeeded * avoidedFraction;
        const headcountSavings = fteAvoided * monthlySalary;

        // Error reduction on manual labor cost
        const errorSavings = manualHours * cost * ERROR_REDUCTION_RATE;

        const grossSavings = headcountSavings + errorSavings;

        // AI cost on top of subscription, with hidden margin baked in.
        const aiCostRaw    = aiCostRawPerPO() * pos;
        const aiCostBilled = aiCostRaw * (1 + HIDDEN_AI_MARGIN);

        // Plan cost: volume-based base fee + value-capture component + AI cost
        // with hidden margin. The customer sees only the final savings/ROI
        // numbers — never the margin breakdown.
        const tierBase     = getTierBase(pos);
        const valueCapture = grossSavings * VALUE_CAPTURE_RATE;
        const planCost     = tierBase + valueCapture + aiCostBilled;
        const netSavings   = grossSavings - planCost;
        const roi          = planCost > 0 ? (Math.max(0, netSavings) / planCost) : 0;

        timeSavedEl.textContent = fmt(manualHours);
        costSavedEl.textContent = '$' + fmt(Math.max(0, netSavings));
        roiEl.textContent = roi.toFixed(1).replace(/\.0$/, '') + 'x';

        if (SHOW_INTERNAL) updateInternalPanel({
          pos,
          aiCostRaw,
          aiCostBilled,
          tierBase,
          valueCapture,
          grossSavings,
          planCost
        });
      }

      function recalcWithPulse(){
        recalc();
        pulse(timeSavedEl);
        pulse(costSavedEl);
      }

      [posEl, timeEl, costEl].forEach(el=>{
        el.addEventListener('input', recalc);
        el.addEventListener('change', recalcWithPulse);
      });

      recalc();

  }
}

customElements.define('peakcontrol-roi-calculator', PeakControlROICalculator);